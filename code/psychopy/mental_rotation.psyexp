        <Param val="msg='empty!'#if this comes up we forgot to update the msg!" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="msg = &quot;empty!&quot;;&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="if ((! CC_resp.keys)) {&amp;#10;    msg = &quot;no answer&quot;;&amp;#10;} else {&amp;#10;    if (CC_resp.corr) {&amp;#10;        msg = &quot;\u0414\u0430! \u041f\u0440\u0430\u0432\u0438\u043b\u044c\u043d\u044b\u0439:&quot;;&amp;#10;    } else {&amp;#10;        msg = &quot;\u041d\u0435\u0442! \u041f\u0440\u0430\u0432\u0438\u043b\u044c\u043d\u044b\u0439:&quot;;&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="if not CC_resp.keys :&amp;#10;    msg=&quot;no answer&quot;&amp;#10;elif CC_resp.corr:#stored on last run routine&amp;#10;    msg=&quot;Да! Правильный:&quot;&amp;#10;else:&amp;#10;    msg=&quot;Нет! Правильный:&quot;" valType="extendedCode" updates="constant" name="Begin Routine"/>

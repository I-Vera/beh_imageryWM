        <Param val="" valType="code" updates="constant" name="stopVal"/>
        <Param val="True" valType="bool" updates="None" name="syncScreenRefresh"/>
        <Param val="Вам будут показаны пары фигур: одна слева, другая справа от центра экрана. Ваша задача — как можно быстрее определить, одинаковые ли это фигуры (одна повёрнута относительно другой) или разные (одна является зеркальным отражением другой).&amp;#10;&amp;#10;Если фигуры одинаковые, нажмите кнопку &quot;←&quot;.&amp;#10;Если фигуры разные (зеркальные), нажмите кнопку &quot;→&quot;.&amp;#10;&amp;#10;Старайтесь не поворачивать голову — используйте только воображение. &amp;#10;&amp;#10;Чтобы начать тренировочный этап, нажмите любую кнопку." valType="str" updates="constant" name="text"/>
        <Param val="from exp settings" valType="str" updates="None" name="units"/>

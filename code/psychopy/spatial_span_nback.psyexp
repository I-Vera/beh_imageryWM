        <Param val="" valType="code" updates="constant" name="stopVal"/>
        <Param val="True" valType="bool" updates="None" name="syncScreenRefresh"/>
        <Param val="Понятен ли вам принцип задания?&amp;#10;&amp;#10;Если да и вы готовы начать основную часть, нажмите &quot;Y&quot;&amp;#10;Если нет и вы хотите еще раз повторить тренировку, нажмите &quot;N&quot;" valType="str" updates="constant" name="text"/>
        <Param val="from exp settings" valType="str" updates="None" name="units"/>

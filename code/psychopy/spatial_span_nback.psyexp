    </Routine>
    <Routine name="trial_2n">
      <CodeComponent name="griddot2" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="n_rows = 3;&amp;#10;n_cols = 3;&amp;#10;grid_size = 0.65;&amp;#10;cell_size = (grid_size / n_rows);&amp;#10;grid_lines = [];&amp;#10;for (var i, _pj_c = 0, _pj_a = util.range((n_rows + 1)), _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;    i = _pj_a[_pj_c];&amp;#10;    y = (((- grid_size) / 2) + (i * cell_size));&amp;#10;    line = new visual.Rect(psychoJS.window, {&quot;width&quot;: grid_size, &quot;height&quot;: 0.01, &quot;pos&quot;: [0, y], &quot;fillColor&quot;: &quot;white&quot;, &quot;lineColor&quot;: &quot;white&quot;});&amp;#10;    grid_lines.push(line);&amp;#10;}&amp;#10;for (var j, _pj_c = 0, _pj_a = util.range((n_cols + 1)), _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;    j = _pj_a[_pj_c];&amp;#10;    x = (((- grid_size) / 2) + (j * cell_size));&amp;#10;    line = new visual.Rect(psychoJS.window, {&quot;width&quot;: 0.01, &quot;height&quot;: grid_size, &quot;pos&quot;: [x, 0], &quot;fillColor&quot;: &quot;white&quot;, &quot;lineColor&quot;: &quot;white&quot;});&amp;#10;    grid_lines.push(line);&amp;#10;}&amp;#10;dot = new visual.Circle(psychoJS.window, {&quot;radius&quot;: 0.04, &quot;fillColor&quot;: &quot;red&quot;, &quot;lineColor&quot;: &quot;red&quot;});&amp;#10;step_duration = 2;&amp;#10;step_index = 0;&amp;#10;step_clock = new core.Clock();&amp;#10;if ((Nloop === 5)) {&amp;#10;    currentLoop.finished = true;&amp;#10;}&amp;#10;Nloop = (Nloop + 1);&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="# Define grid parameters&amp;#10;n_rows = 3&amp;#10;n_cols = 3&amp;#10;grid_size = 0.65  # size in normalized units (0 to 1)&amp;#10;cell_size = grid_size / n_rows&amp;#10;&amp;#10;# Create grid lines using Rect&amp;#10;grid_lines = []&amp;#10;for i in range(n_rows + 1):&amp;#10;    # Horizontal lines&amp;#10;    y = -grid_size/2 + i*cell_size&amp;#10;    line = visual.Rect(win, width=grid_size, height=0.01, pos=(0, y), fillColor='white', lineColor='white')&amp;#10;    grid_lines.append(line)&amp;#10;&amp;#10;for j in range(n_cols + 1):&amp;#10;    # Vertical lines&amp;#10;    x = -grid_size/2 + j*cell_size&amp;#10;    line = visual.Rect(win, width=0.01, height=grid_size, pos=(x, 0), fillColor='white', lineColor='white')&amp;#10;    grid_lines.append(line)&amp;#10;&amp;#10;# Create the dot&amp;#10;dot = visual.Circle(win, radius=0.04, fillColor='red', lineColor='red')&amp;#10;&amp;#10;step_duration = 2  # seconds per step&amp;#10;step_index = 0&amp;#10;step_clock = core.Clock()&amp;#10;&amp;#10;if Nloop == 5:&amp;#10;    currentLoop.finished = True&amp;#10;Nloop = Nloop+1" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="if step_index &lt; len(sequence):&amp;#10;    row_index, col_index = sequence[step_index]&amp;#10;    dot.pos = (-grid_size/2 + (col_index + 0.5) * cell_size,&amp;#10;               -grid_size/2 + (row_index + 0.5) * cell_size)&amp;#10;&amp;#10;    # Set color for first two dots, else default to red&amp;#10;    if step_index &lt; 2:&amp;#10;        dot.fillColor = 'orange'&amp;#10;        dot.lineColor = 'orange'&amp;#10;    else:&amp;#10;        dot.fillColor = 'red'&amp;#10;        dot.lineColor = 'red'&amp;#10;&amp;#10;    for line in grid_lines:&amp;#10;        line.draw()&amp;#10;&amp;#10;    current_time = step_clock.getTime()&amp;#10;&amp;#10;    # Draw dot only if within first 1.8 seconds of the step&amp;#10;    if current_time &lt; 1.8:&amp;#10;        dot.draw()&amp;#10;&amp;#10;    if current_time &gt;= step_duration:  # step_duration should be 2.0 seconds&amp;#10;        step_clock.reset()&amp;#10;        step_index += 1&amp;#10;else:&amp;#10;    continueRoutine = False&amp;#10;" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="if ((step_index &lt; sequence.length)) {&amp;#10;    [row_index, col_index] = sequence[step_index];&amp;#10;    dot.pos = [(((- grid_size) / 2) + ((col_index + 0.5) * cell_size)), (((- grid_size) / 2) + ((row_index + 0.5) * cell_size))];&amp;#10;    if ((step_index &lt; 2)) {&amp;#10;        dot.fillColor = &quot;orange&quot;;&amp;#10;        dot.lineColor = &quot;orange&quot;;&amp;#10;    } else {&amp;#10;        dot.fillColor = &quot;red&quot;;&amp;#10;        dot.lineColor = &quot;red&quot;;&amp;#10;    }&amp;#10;    for (var line, _pj_c = 0, _pj_a = grid_lines, _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;        line = _pj_a[_pj_c];&amp;#10;        line.draw();&amp;#10;    }&amp;#10;    current_time = step_clock.getTime();&amp;#10;    if ((current_time &lt; 1.8)) {&amp;#10;        dot.draw();&amp;#10;    }&amp;#10;    if ((current_time &gt;= step_duration)) {&amp;#10;        step_clock.reset();&amp;#10;        step_index += 1;&amp;#10;    }&amp;#10;} else {&amp;#10;    continueRoutine = false;&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="griddot2" valType="code" updates="None" name="name"/>
      </CodeComponent>
      <KeyboardComponent name="griddot_resp2" plugin="None">
        <Param val="'left','right'" valType="list" updates="set every repeat" name="allowedKeys"/>
        <Param val="" valType="str" updates="constant" name="correctAns"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="True" valType="bool" updates="constant" name="discard previous"/>
        <Param val="" valType="code" updates="None" name="durationEstim"/>
        <Param val="False" valType="bool" updates="constant" name="forceEndRoutine"/>
        <Param val="griddot_resp2" valType="code" updates="None" name="name"/>
        <Param val="press" valType="str" updates="constant" name="registerOn"/>
        <Param val="True" valType="bool" updates="None" name="saveStartStop"/>
        <Param val="" valType="code" updates="None" name="startEstim"/>
        <Param val="time (s)" valType="str" updates="None" name="startType"/>
        <Param val="0.0" valType="code" updates="None" name="startVal"/>
        <Param val="duration (s)" valType="str" updates="None" name="stopType"/>
        <Param val="16" valType="code" updates="constant" name="stopVal"/>
        <Param val="all keys" valType="str" updates="constant" name="store"/>
        <Param val="False" valType="bool" updates="constant" name="storeCorrect"/>
        <Param val="True" valType="bool" updates="constant" name="syncScreenRefresh"/>
      </KeyboardComponent>
    </Routine>
    <Routine name="trial_3n">
      <CodeComponent name="griddot3" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="n_rows = 3;&amp;#10;n_cols = 3;&amp;#10;grid_size = 0.65;&amp;#10;cell_size = (grid_size / n_rows);&amp;#10;grid_lines = [];&amp;#10;for (var i, _pj_c = 0, _pj_a = util.range((n_rows + 1)), _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;    i = _pj_a[_pj_c];&amp;#10;    y = (((- grid_size) / 2) + (i * cell_size));&amp;#10;    line = new visual.Rect(psychoJS.window, {&quot;width&quot;: grid_size, &quot;height&quot;: 0.01, &quot;pos&quot;: [0, y], &quot;fillColor&quot;: &quot;white&quot;, &quot;lineColor&quot;: &quot;white&quot;});&amp;#10;    grid_lines.push(line);&amp;#10;}&amp;#10;for (var j, _pj_c = 0, _pj_a = util.range((n_cols + 1)), _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;    j = _pj_a[_pj_c];&amp;#10;    x = (((- grid_size) / 2) + (j * cell_size));&amp;#10;    line = new visual.Rect(psychoJS.window, {&quot;width&quot;: 0.01, &quot;height&quot;: grid_size, &quot;pos&quot;: [x, 0], &quot;fillColor&quot;: &quot;white&quot;, &quot;lineColor&quot;: &quot;white&quot;});&amp;#10;    grid_lines.push(line);&amp;#10;}&amp;#10;dot = new visual.Circle(psychoJS.window, {&quot;radius&quot;: 0.04, &quot;fillColor&quot;: &quot;red&quot;, &quot;lineColor&quot;: &quot;red&quot;});&amp;#10;step_duration = 2;&amp;#10;step_index = 0;&amp;#10;step_clock = new core.Clock();&amp;#10;if ((Nloop === 5)) {&amp;#10;    currentLoop.finished = true;&amp;#10;}&amp;#10;Nloop = (Nloop + 1);&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="# Define grid parameters&amp;#10;n_rows = 3&amp;#10;n_cols = 3&amp;#10;grid_size = 0.65  # size in normalized units (0 to 1)&amp;#10;cell_size = grid_size / n_rows&amp;#10;&amp;#10;# Create grid lines using Rect&amp;#10;grid_lines = []&amp;#10;for i in range(n_rows + 1):&amp;#10;    # Horizontal lines&amp;#10;    y = -grid_size/2 + i*cell_size&amp;#10;    line = visual.Rect(win, width=grid_size, height=0.01, pos=(0, y), fillColor='white', lineColor='white')&amp;#10;    grid_lines.append(line)&amp;#10;&amp;#10;for j in range(n_cols + 1):&amp;#10;    # Vertical lines&amp;#10;    x = -grid_size/2 + j*cell_size&amp;#10;    line = visual.Rect(win, width=0.01, height=grid_size, pos=(x, 0), fillColor='white', lineColor='white')&amp;#10;    grid_lines.append(line)&amp;#10;&amp;#10;# Create the dot&amp;#10;dot = visual.Circle(win, radius=0.04, fillColor='red', lineColor='red')&amp;#10;&amp;#10;step_duration = 2  # seconds per step&amp;#10;step_index = 0&amp;#10;step_clock = core.Clock()&amp;#10;&amp;#10;if Nloop == 5:&amp;#10;    currentLoop.finished = True&amp;#10;Nloop = Nloop+1" valType="extendedCode" updates="constant" name="Begin Routine"/>
